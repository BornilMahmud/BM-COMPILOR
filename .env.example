# ─────────────────────────────────────────────
#  BM Compiler — Environment Variables
#  Copy this file to .env for local development
#  Never commit .env to Git
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
# Port the Express server listens on
# Render sets this automatically to 10000
PORT=5000

# ── Firebase Authentication ───────────────────
# These come from your Firebase project settings:
# https://console.firebase.google.com/project/bm-compilor/settings/general
#
# VITE_ prefix required — Vite injects these into the browser bundle at build time

VITE_FIREBASE_API_KEY=AIzaSyC7X7EdNzEJe6IIXTrYCmgmcTgKXj_RJFo
VITE_FIREBASE_PROJECT_ID=bm-compilor
VITE_FIREBASE_APP_ID=1:98358335395:web:22e3d5fcd3181219b42c16
